              "    pm.expect(jsonData.name).to.eql(pm.iterationData.get(\"boardName\"));    //to check from CSV data\r",
              "});\r",
              "\r",
              "pm.environment.set(\"boardId\", jsonData.id);\r",
              "\r",
              "console.log(\"Board ID:\", jsonData.id);"
